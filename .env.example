# ─── GitHub App ───────────────────────────────────────────────────────────────
# GitHub App numeric ID (from app settings page)
GITHUB_APP_ID=

# RSA private key – paste the full PEM as a single-line string with \n literal
# e.g. "-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
GITHUB_PRIVATE_KEY=

# Secret configured in the GitHub App webhook settings
GITHUB_WEBHOOK_SECRET=

# ─── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# Groq model to use
LLM_MODEL=llama3-70b-8192

# ─── Queue ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# Number of concurrent PR-review jobs processed by the worker pool
QUEUE_CONCURRENCY=3

# Max delivery attempts before a job is dead-lettered
QUEUE_MAX_ATTEMPTS=3

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# Public base URL of this service (used in GitHub App webhook config)
BASE_URL=https://your-domain.example.com

# ─── Optional ─────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info
