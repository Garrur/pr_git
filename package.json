{
  "name": "pr-pilot",
  "version": "1.0.0",
  "description": "GitHub App that auto-reviews PRs using Claude LLM",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node -r dotenv/config src/index.ts",
    "worker": "ts-node -r dotenv/config src/worker/index.ts",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/formbody": "^7.4.0",
    "@octokit/auth-app": "^7.1.1",
    "@octokit/rest": "^20.1.1",
    "distri-task-sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "ioredis": "^5.4.1",
    "pino": "^9.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/redis": "^10.13.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.8.0",
    "jest": "^29.7.0",
    "nock": "^13.5.4",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^10.13.2",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testTimeout": 60000,
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "setupFiles": [
      "<rootDir>/tests/setup.ts"
    ]
  }
}
